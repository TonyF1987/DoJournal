<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goToHome">
      <text class="back-icon">‹</text>
    </view>
    <text class="nav-title">登录</text>
    <view class="nav-right"></view>
  </view>

  <!-- 品牌区域 -->
  <view class="brand-section">
    <view class="logo-box">
      <text class="logo-icon">📚</text>
    </view>
    <text class="app-name">作业打卡</text>
  </view>

  <!-- 用户头像和昵称 -->
  <view class="user-info-section">
    <!-- 头像和昵称显示 -->
    <view class="user-info-display">
      <image class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}"></image>
      <view class="avatar-placeholder" wx:else>
        <text class="placeholder-icon">👤</text>
      </view>
      <text class="nickname-text" wx:if="{{nickName}}">{{nickName}}</text>
      <text class="nickname-placeholder" wx:else>点击下方按钮获取用户信息</text>
    </view>
    <!-- 获取用户信息按钮（同时也是头像选择按钮） -->
    <button class="get-user-info-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <text>{{avatarUrl && nickName ? '重新获取' : '获取用户信息'}}</text>
    </button>
    <!-- 昵称输入框 -->
    <view class="nickname-input-wrapper">
      <input
        class="nickname-input"
        type="nickname"
        placeholder="昵称将自动填充"
        value="{{nickName}}"
        bindinput="onNicknameInput"
        maxlength="20"
        focus="{{nicknameFocus}}"
      />
    </view>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <view class="input-group">
      <input
        class="form-input"
        type="text"
        placeholder="请输入手机号或账号"
        value="{{phoneNumber}}"
        bindinput="onPhoneInput"
        maxlength="50"
      />
    </view>

    <view class="input-group">
      <input
        wx:if="{{showPassword}}"
        class="form-input"
        type="text"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
      <input
        wx:if="{{!showPassword}}"
        class="form-input"
        type="password"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
      <view class="password-eye" bindtap="togglePassword">
        <text>{{showPassword ? '🔓' : '🔒'}}</text>
      </view>
    </view>

    <!-- 协议 -->
    <view class="agreement-section">
      <text class="text-mini">请阅读</text>
      <text class="text-link" bindtap="goToServiceAgreement">《服务协议》</text>
      <text class="text-mini">和</text>
      <text class="text-link" bindtap="goToPrivacyPolicy">《隐私政策》</text>
    </view>

    <!-- 提交按钮 -->
    <button class="btn-submit {{!canSubmitValue ? 'disabled' : ''}}" bindtap="handleSubmit" disabled="{{!canSubmitValue}}">
      <text>{{isLoading ? '处理中...' : '登录/注册'}}</text>
    </button>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-space"></view>
</view>

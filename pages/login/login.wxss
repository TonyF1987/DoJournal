page {
  background-color: #ffffff;
  min-height: 100vh;
}

.container {
  padding: 0;
  min-height: 100vh;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 64rpx;
  color: #333333;
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
}

.nav-right {
  width: 60rpx;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.logo-box {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.logo-icon {
  font-size: 72rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
}

/* 用户信息区域 */
.user-info-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 64rpx 40rpx;
}

.user-info-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: #f0f0f0;
  margin-bottom: 16rpx;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.placeholder-icon {
  font-size: 64rpx;
}

.nickname-text {
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
}

.nickname-placeholder {
  font-size: 28rpx;
  color: #999999;
}

.get-user-info-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  line-height: 1.5;
}

.get-user-info-btn::after {
  border: none;
}

.nickname-input-wrapper {
  width: 100%;
  margin-top: 20rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  text-align: center;
  box-sizing: border-box;
}

/* 隐藏的昵称输入框（用于获取微信昵称） */
.nickname-input-hidden {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.01;
  z-index: 1;
}

/* 表单区域 */
.form-section {
  padding: 0 64rpx;
}

.input-group {
  margin-bottom: 32rpx;
  position: relative;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background-color: #f8f8f8;
  border-radius: 48rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

/* 密码输入框 */
.password-eye {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* 协议区域 */
.agreement-section {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 48rpx;
}

.checkbox {
  transform: scale(0.9);
  margin-right: 8rpx;
}

.text-mini {
  font-size: 24rpx;
  color: #666666;
}

.text-link {
  font-size: 24rpx;
  color: #4CAF50;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s;
}

.btn-submit.disabled {
  background: #e0e0e0;
  color: #999999;
}

/* 底部占位 */
.bottom-space {
  height: 80rpx;
}

/* 账号输入框组 */
.account-input-group {
  position: relative;
}

.account-input {
  padding-right: 80rpx;
}

/* 下拉箭头 */
.dropdown-arrow {
  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  z-index: 10;
}

.arrow-icon {
  font-size: 24rpx;
  color: #999999;
  transition: transform 0.3s;
}

.arrow-icon.up {
  transform: rotate(180deg);
}

/* 账号下拉列表 */
.account-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  margin-top: 8rpx;
  overflow: hidden;
  z-index: 9999;
  max-height: 500rpx;
  overflow-y: auto;
}

.dropdown-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  transition: background-color 0.2s;
  border-bottom: 1rpx solid #f5f5f5;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background-color: #f5f5f5;
}

.dropdown-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.dropdown-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 36rpx;
}

.dropdown-avatar text {
  font-size: 32rpx;
}

.dropdown-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.dropdown-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.dropdown-account {
  font-size: 24rpx;
  color: #999999;
}

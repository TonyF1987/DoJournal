/* 登录页面样式 */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 0 30rpx;
}

/* 顶部装饰 */
.top-decoration {
  text-align: center;
  padding: 120rpx 0 80rpx;
}

.main-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-20rpx);
  }
  60% {
    transform: translateY(-10rpx);
  }
}

.main-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.main-subtitle {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

/* 登录区域 */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

/* 用户表单 */
.user-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* 头像选择 */
.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #4CAF50;
  overflow: hidden;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.avatar-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  font-size: 20rpx;
  padding: 8rpx 0;
  text-align: center;
}

/* 昵称输入 */
.nickname-wrapper {
  width: 100%;
  margin-bottom: 30rpx;
}

.nickname-input {
  width: 100%;
  padding: 24rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 30rpx;
  background: white;
}

/* 手机号授权 */
.phone-wrapper {
  width: 100%;
  margin-bottom: 20rpx;
}

.phone-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #2196F3, #1976D2);
  color: white;
  border-radius: 16rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.phone-icon {
  font-size: 32rpx;
}

.phone-hint {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin-top: 12rpx;
}

.phone-display {
  width: 100%;
  padding: 24rpx;
  background: #f0f9ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.phone-text {
  font-size: 28rpx;
  color: #333;
}

.phone-change {
  font-size: 24rpx;
  color: #2196F3;
  margin-left: 20rpx;
}

/* 用户预览 */
.user-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.user-phone {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.logout-btn {
  padding: 16rpx 40rpx;
  background: #f44336;
  color: white;
  border-radius: 50rpx;
  font-size: 26rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  padding: 30rpx 0;
  font-size: 36rpx;
  border-radius: 50rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.btn-login {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
}

.btn-logged {
  background: linear-gradient(135deg, #90A4AE, #B0BEC5);
  color: white;
}

.login-btn:active {
  transform: scale(0.98);
}

/* 登录说明 */
.login-description {
  font-size: 24rpx;
  color: #888;
  text-align: center;
  line-height: 1.4;
}

/* 功能特点 */
.features-section {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFE0B2, #FFCC80);
  border-radius: 16rpx;
  font-size: 32rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-description {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 响应式设计 */
@media screen and (max-height: 800px) {
  .top-decoration {
    padding: 80rpx 0 60rpx;
  }
  
  .main-icon {
    font-size: 100rpx;
  }
  
  .main-title {
    font-size: 40rpx;
  }
  
  .main-subtitle {
    font-size: 24rpx;
  }
  
  .login-section {
    margin-bottom: 60rpx;
  }
  
  .user-preview {
    padding: 30rpx;
  }
  
  .user-avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .user-name {
    font-size: 28rpx;
  }
  
  .login-btn {
    padding: 24rpx 0;
    font-size: 32rpx;
  }
  
  .features-section {
    padding: 30rpx;
  }
  
  .feature-item {
    margin-bottom: 24rpx;
  }
  
  .feature-icon {
    width: 50rpx;
    height: 50rpx;
    font-size: 28rpx;
  }
  
  .feature-title {
    font-size: 28rpx;
  }
  
  .feature-description {
    font-size: 24rpx;
  }
}
page {
  background-color: #ffffff;
  min-height: 100vh;
}

.container {
  padding: 0;
  min-height: 100vh;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 64rpx;
  color: #333333;
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
}

.nav-right {
  width: 60rpx;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.logo-box {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.logo-icon {
  font-size: 72rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
}

/* 用户信息区域 */
.user-info-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 64rpx 40rpx;
}

.user-info-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: #f0f0f0;
  margin-bottom: 16rpx;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.placeholder-icon {
  font-size: 64rpx;
}

.nickname-text {
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
}

.nickname-placeholder {
  font-size: 28rpx;
  color: #999999;
}

.get-user-info-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  line-height: 1.5;
}

.get-user-info-btn::after {
  border: none;
}

.nickname-input-wrapper {
  width: 100%;
  margin-top: 20rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  text-align: center;
  box-sizing: border-box;
}

/* 表单区域 */
.form-section {
  padding: 0 64rpx;
}

.input-group {
  margin-bottom: 32rpx;
  position: relative;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background-color: #f8f8f8;
  border-radius: 48rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

/* 密码输入框 */
.password-eye {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* 协议区域 */
.agreement-section {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 48rpx;
}

.checkbox {
  transform: scale(0.9);
  margin-right: 8rpx;
}

.text-mini {
  font-size: 24rpx;
  color: #666666;
}

.text-link {
  font-size: 24rpx;
  color: #4CAF50;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s;
}

.btn-submit.disabled {
  background: #e0e0e0;
  color: #999999;
}

/* 底部占位 */
.bottom-space {
  height: 80rpx;
}

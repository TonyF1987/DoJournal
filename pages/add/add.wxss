/* 页面滚动容器 */
page {
  height: 100%;
  background: #f5f5f5;
}

.scroll-container {
  height: 100vh;
  width: 100%;
}

.container {
  padding: 24rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
  display: block;
  line-height: 1.4;
}

.form-input-container {
  width: 100%;
  margin-top: 0;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 88rpx;
}

.form-textarea-container {
  width: 100%;
  margin-top: 0;
}

.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  min-height: 180rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  padding: 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  text-align: center;
  transition: all 0.3s;
}

.type-item.active {
  border-color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
}

.type-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 10rpx;
}

.type-text {
  font-size: 24rpx;
  color: #666;
}

.import-instruction {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.step-num {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-left: 20rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: #666;
}

/* 快捷操作按钮 */
.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #f5f7fa, #e8ecf1);
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.3s;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.action-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.action-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* 已导入内容预览 */
.import-preview-section {
  margin-top: 30rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.preview-count {
  font-size: 24rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 转发说明 */
.forward-guide {
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.guide-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.guide-step {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.guide-step:last-child {
  margin-bottom: 0;
}

.step-badge {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.guide-step .step-text {
  font-size: 26rpx;
  color: #666;
}

.import-btn {
  width: 100%;
  padding: 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.import-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.preview-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.preview-item {
  position: relative;
}

.preview-item image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  border-radius: 50%;
  font-size: 24rpx;
  z-index: 10;
}

.image-action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-primary {
  flex: 1;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.btn-secondary {
  flex: 1;
  padding: 24rpx 30rpx;
  background: #f5f5f5;
  color: #333;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 1px solid #ddd;
}

.preview-item.text {
  width: 100%;
  height: auto;
  padding: 20rpx;
}

.preview-item.text text {
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.recurring-days {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.day-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s;
}

.day-item.active {
  background: #4CAF50;
  color: #fff;
}

.tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #ff5252;
}

.points-selector {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.point-item {
  flex: 1;
  min-width: 100rpx;
  padding: 20rpx 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.point-item.active {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
  font-weight: bold;
}

.points-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #fff9c4, #fff59d);
  border-radius: 16rpx;
}

.points-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #FF9800;
  line-height: 1;
}

.points-unit {
  font-size: 28rpx;
  color: #F57C00;
  margin-left: 8rpx;
}

.custom-points-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.custom-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  text-align: center;
}

.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.stepper-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 40rpx;
  color: #666;
  transition: all 0.2s;
}

.stepper-btn:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

.stepper-btn.plus {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
}

.stepper-btn.minus {
  background: linear-gradient(135deg, #ff7043, #f4511e);
  color: #fff;
}

.stepper-input {
  width: 160rpx;
  height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.submit-section {
  padding: 20rpx;
  margin-top: 20rpx;
}

.btn-submit {
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.btn-submit[disabled] {
  background: #e0e0e0;
  color: #999;
}

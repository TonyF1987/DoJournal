<view class="container">
  <!-- 作业详情 -->
  <view class="card" wx:if="{{homework}}">
    <view class="homework-header">
      <text class="homework-title">{{homework.title}}</text>
      <view class="points-badge">+{{homework.points}}分</view>
    </view>
    <text class="homework-content">{{homework.content}}</text>
    <view class="homework-meta">
      <text class="homework-time">{{homework.createTime}}</text>
      <text class="homework-tag" wx:if="{{homework.type === 'recurring'}}">周期作业</text>
    </view>

    <!-- 作业图片 -->
    <view class="homework-images" wx:if="{{homework.images && homework.images.length > 0}}">
      <image wx:for="{{homework.images}}" wx:key="index" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" data-urls="{{homework.images}}"></image>
    </view>
  </view>

  <!-- 上传凭证 -->
  <view class="card">
    <view class="form-label">上传完成凭证 *</view>
    <view class="upload-section">
      <view class="upload-item" wx:if="{{proofImage}}" bindtap="chooseProofImage">
        <image src="{{proofImage}}" mode="aspectFill"></image>
        <view class="delete-icon" catchtap="deleteProofImage">×</view>
      </view>
      <view class="upload-btn" wx:if="{{!proofImage}}" bindtap="chooseProofImage">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击拍照或相册选择</text>
      </view>
    </view>
  </view>

  <!-- 等级评价 -->
  <view class="card">
    <view class="form-label">完成质量评价</view>
    <view class="rating-section">
      <view class="rating-options">
        <view class="rating-item {{rating === 3 ? 'active excellent' : ''}}" bindtap="selectRating" data-rating="3">
          <view class="rating-stars">⭐⭐⭐</view>
          <view class="rating-label">优秀</view>
          <view class="rating-percent">100%</view>
        </view>
        <view class="rating-item {{rating === 2 ? 'active good' : ''}}" bindtap="selectRating" data-rating="2">
          <view class="rating-stars">⭐⭐</view>
          <view class="rating-label">良好</view>
          <view class="rating-percent">80%</view>
        </view>
        <view class="rating-item {{rating === 1 ? 'active pass' : ''}}" bindtap="selectRating" data-rating="1">
          <view class="rating-stars">⭐</view>
          <view class="rating-label">合格</view>
          <view class="rating-percent">60%</view>
        </view>
      </view>
      <view class="rating-result" wx:if="{{rating > 0 && homework}}">
        <text class="result-text">预计获得：</text>
        <text class="result-points">{{actualPoints}}积分</text>
        <text class="result-base" wx:if="{{rating < 3}}">（基础{{homework.points}}分 × {{ratingPercent}}%）</text>
      </view>
    </view>
  </view>

  <!-- 打卡评语 -->
  <view class="card">
    <view class="form-label">打卡评语（可选）</view>
    <view class="comment-input-wrapper">
      <textarea class="comment-input" placeholder="记录一下完成心得..." value="{{comment}}" bindinput="onCommentInput" maxlength="200"></textarea>
      <text class="char-count">{{comment.length}}/200</text>
    </view>
  </view>

  <!-- 打卡按钮 -->
  <view class="submit-section">
    <button class="btn-submit" bindtap="submitCheckIn" disabled="{{!proofImage || rating === 0}}">完成打卡</button>
    <text class="tip">上传凭证并选择评价后即可打卡</text>
  </view>

  <!-- 积分说明 -->
  <view class="card tips">
    <view class="tips-title">积分说明</view>
    <text class="tips-content">• ⭐⭐⭐ 优秀：获得100%基础积分</text>
    <text class="tips-content">• ⭐⭐ 良好：获得80%基础积分</text>
    <text class="tips-content">• ⭐ 合格：获得60%基础积分</text>
    <text class="tips-content">• 连续打卡可获得额外奖励</text>
  </view>
</view>

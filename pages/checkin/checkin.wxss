/* 页面滚动容器 */
page {
  height: auto;
  min-height: 100vh;
  box-sizing: border-box;
  max-width: 100vw;
  overflow-x: hidden;
}

.homework-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.homework-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.homework-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.homework-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.homework-time {
  font-size: 24rpx;
  color: #999;
}

.homework-tag {
  font-size: 20rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.homework-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.homework-images image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.upload-section {
  display: flex;
  gap: 16rpx;
}

.upload-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.upload-item image {
  width: 100%;
  height: 100%;
}

.delete-icon {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #e0e0e0;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.comment-input-wrapper {
  position: relative;
}

.comment-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  font-size: 22rpx;
  color: #ccc;
}

.rating-section {
  width: 100%;
}

.rating-options {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.rating-item {
  flex: 1;
  padding: 24rpx 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  text-align: center;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.rating-item.active {
  transform: scale(1.02);
}

.rating-item.active.excellent {
  background: rgba(76, 175, 80, 0.15);
  border-color: #4CAF50;
}

.rating-item.active.good {
  background: rgba(33, 150, 243, 0.15);
  border-color: #2196F3;
}

.rating-item.active.pass {
  background: rgba(255, 152, 0, 0.15);
  border-color: #FF9800;
}

.rating-stars {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.rating-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.rating-percent {
  font-size: 22rpx;
  color: #999;
}

.rating-item.active.excellent .rating-label {
  color: #4CAF50;
}

.rating-item.active.excellent .rating-percent {
  color: #4CAF50;
}

.rating-item.active.good .rating-label {
  color: #2196F3;
}

.rating-item.active.good .rating-percent {
  color: #2196F3;
}

.rating-item.active.pass .rating-label {
  color: #FF9800;
}

.rating-item.active.pass .rating-percent {
  color: #FF9800;
}

.rating-result {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #fff9c4, #fff59d);
  border-radius: 12rpx;
}

.result-text {
  font-size: 26rpx;
  color: #666;
}

.result-points {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF9800;
  margin: 0 8rpx;
}

.result-base {
  font-size: 22rpx;
  color: #999;
}

.submit-section {
  padding: 40rpx 20rpx;
}

.btn-submit {
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.btn-submit[disabled] {
  background: #e0e0e0;
  color: #999;
}

.tip {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.tips {
  background: linear-gradient(135deg, #e3f2fd, #bbdefb);
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #1976d2;
}

.tips-content {
  display: block;
  font-size: 24rpx;
  color: #1976d2;
  line-height: 2;
}

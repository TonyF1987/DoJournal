page {
  background: linear-gradient(180deg, #f0f7f0 0%, #f5f5f5 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  max-width: 100%;
  overflow-x: hidden;
}

.header-gradient {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  padding: 60rpx 24rpx 40rpx;
}

.user-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  overflow: hidden;
}

.user-avatar .user-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.user-desc {
  font-size: 26rpx;
  color: #999;
}

.content-area {
  padding: 24rpx;
  margin-top: -20rpx;
}

.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  gap: 20rpx;
  transition: background 0.2s;
}

.menu-item:active {
  background: #f5f5f5;
}

.menu-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f7f0, #e8f5e9);
}

.menu-icon {
  font-size: 44rpx;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.menu-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 24rpx;
}

.version-info {
  text-align: center;
  padding: 40rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #ccc;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 16rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.family-info-card {
  background: linear-gradient(135deg, #f0f7f0, #e8f5e9);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  margin-bottom: 32rpx;
}

.family-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.family-desc {
  font-size: 26rpx;
  color: #666;
}

.family-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.family-members-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.family-member {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  overflow: hidden;
}

.member-avatar .member-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.member-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-name {
  font-size: 28rpx;
  color: #333;
}

.member-role {
  font-size: 20rpx;
  color: #fff;
  background: #4CAF50;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.family-actions {
  display: flex;
  gap: 16rpx;
}

.family-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.btn-cancel {
  flex: 1;
  padding: 28rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
}

.btn-confirm {
  flex: 1;
  padding: 28rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  font-weight: bold;
  text-align: center;
}

.btn-danger {
  flex: 1;
  padding: 28rpx;
  background: linear-gradient(135deg, #f44336, #e53935);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  font-weight: bold;
  text-align: center;
}

.invite-code-card {
  background: linear-gradient(135deg, #f0f7f0, #e8f5e9);
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
}

.invite-code {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.invite-code-desc {
  font-size: 26rpx;
  color: #666;
}

.edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  border: 3rpx solid #fff;
}

.user-card {
  position: relative;
}

.user-avatar {
  position: relative;
}

.user-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.logout-section {
  margin-top: 40rpx;
  padding: 0 24rpx;
}

.logout-btn {
  width: 100%;
  padding: 28rpx;
  background: #fff;
  border: 2rpx solid #f44336;
  color: #f44336;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 500;
}

.logout-btn:active {
  background: #f44336;
  color: #fff;
}

.edit-avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.edit-avatar {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.edit-avatar-placeholder {
  font-size: 64rpx;
  color: #fff;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 0;
  text-align: center;
}
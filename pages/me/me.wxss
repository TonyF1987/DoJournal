page {
  background: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  max-width: 100%;
  overflow-x: hidden;
}

/* 顶部区域 */
.top-section {
  background: #fff;
  padding: 0;
  margin-bottom: 20rpx;
}

/* 未登录登录按钮 */
.login-prompt {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  gap: 24rpx;
}

.login-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-icon {
  font-size: 60rpx;
}

.login-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.login-desc {
  font-size: 26rpx;
  color: #999;
}

.login-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 已登录用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  gap: 24rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  overflow: hidden;
}

.user-avatar .user-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.user-desc {
  font-size: 26rpx;
  color: #999;
}

.user-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 菜单区域 */
.menu-section {
  background: #fff;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  gap: 20rpx;
  transition: background 0.2s;
}

.menu-item:active {
  background: #f5f5f5;
}

.menu-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f7f0, #e8f5e9);
}

.menu-icon {
  font-size: 44rpx;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-hint {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 179, 71, 0.1);
  padding: 6rpx 12rpx;
  border-radius: 30rpx;
}

.hint-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFB347;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.hint-text {
  font-size: 20rpx;
  color: #FFB347;
  font-weight: 500;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.menu-item-danger .menu-title {
  color: #FF5252;
}

.menu-item-danger .menu-desc {
  color: #FF8A80;
}

.menu-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 32rpx;
}

/* 退出登录按钮 */
.logout-section {
  margin-top: 40rpx;
  padding: 0 32rpx;
}

.logout-btn {
  width: 100%;
  padding: 28rpx;
  background: #fff;
  border: none;
  color: #333;
  border-radius: 0;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
}

.logout-btn:active {
  background: #f5f5f5;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #ccc;
}

/* 模态框样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 16rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.family-info-card {
  background: linear-gradient(135deg, #f0f7f0, #e8f5e9);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  margin-bottom: 32rpx;
}

.family-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.family-desc {
  font-size: 26rpx;
  color: #666;
}

.family-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.family-members-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.family-member {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  overflow: hidden;
}

.member-avatar .member-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.member-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-name {
  font-size: 28rpx;
  color: #333;
}

.member-role {
  font-size: 20rpx;
  color: #fff;
  background: #4CAF50;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.member-readonly {
  background: #FF9800;
}

.member-badges {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.member-actions {
  display: flex;
  gap: 12rpx;
}

.btn-small {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.btn-action {
  background: #fff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
}

.btn-action.btn-danger {
  color: #FF5252;
  border-color: #FF5252;
}

.btn-confirm.btn-danger {
  background: linear-gradient(135deg, #f44336, #ff5252);
}

.edit-family-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4CAF50;
  cursor: pointer;
}

.warning-text {
  text-align: center;
  margin-bottom: 24rpx;
}

.warning-text text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF5252;
}

.warning-desc {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.warning-desc text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.family-actions {
  display: flex;
  gap: 16rpx;
}

.family-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.btn-cancel {
  flex: 1;
  padding: 28rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
}

.btn-confirm {
  flex: 1;
  padding: 28rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  font-weight: bold;
  text-align: center;
}

.btn-danger {
  flex: 1;
  padding: 28rpx;
  background: #fff;
  color: #f44336;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  font-weight: bold;
  text-align: center;
}

.invite-code-card {
  background: linear-gradient(135deg, #f0f7f0, #e8f5e9);
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
}

.invite-code {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.invite-code-desc {
  font-size: 26rpx;
  color: #666;
}

.edit-avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.edit-avatar {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.edit-avatar-placeholder {
  font-size: 64rpx;
  color: #fff;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 0;
  text-align: center;
}

.settings-list {
  padding: 16rpx 0;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settings-icon {
  font-size: 36rpx;
}

.settings-title {
  font-size: 30rpx;
  color: #333;
}

.settings-switch {
  transform: scale(0.9);
}

.help-modal-content {
  max-height: 70vh;
}

.help-body {
  padding: 0 8rpx;
}

.help-section {
  margin-bottom: 40rpx;
}

.help-section:last-child {
  margin-bottom: 0;
}

.help-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.help-item {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  padding-left: 8rpx;
}

/* 成员账号显示 */
.member-account {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 6rpx;
}

.account-label {
  font-size: 24rpx;
  color: #999;
}

.account-value {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 账号列表 */
.account-list {
  max-height: 50vh;
  overflow-y: auto;
}

.account-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.account-item:last-child {
  border-bottom: none;
}

.account-avatar-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.account-avatar-img {
  width: 100%;
  height: 100%;
}

.account-info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 20rpx;
}

.account-name-item {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.account-tag-item {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.add-icon {
  font-size: 48rpx;
  color: #4CAF50;
  font-weight: bold;
}
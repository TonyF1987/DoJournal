page {
  background: linear-gradient(180deg, #f0f7f0 0%, #f5f5f5 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  max-width: 100%;
  overflow-x: hidden;
}

/* 演示数据提示条 */
.demo-banner {
  background: linear-gradient(135deg, #FFB347, #FFCC33);
  margin: -24rpx -24rpx 24rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12rpx;
}

.demo-icon {
  font-size: 36rpx;
}

.demo-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.demo-login-btn {
  background: #fff;
  color: #4CAF50;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.header-gradient {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  padding: 30rpx 24rpx 40rpx;
}

.user-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  overflow: hidden;
}

.user-avatar .user-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.user-desc {
  font-size: 22rpx;
  color: #999;
}

.user-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.tab-bar {
  display: flex;
  background: linear-gradient(135deg, #ffffff, #f8f8f8);
  margin: -20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 20rpx;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.tab-item {
  flex: 1;
  padding: 32rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #666;
  border-radius: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.tab-item:active {
  transform: scale(0.96);
}

.tab-item.active {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.content-area {
  padding: 24rpx;
  min-height: 600rpx;
}

.tab-content {
  display: block;
  animation: fadeIn 0.3s ease;
}

.tab-content[hidden] {
  display: none !important;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.grid-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.grid-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.item-icon-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.item-emoji {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 24rpx;
}

.item-emoji.punishment {
  background: linear-gradient(135deg, #ffebee, #ffcdd2);
}

.item-actions {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  display: flex;
  gap: 8rpx;
}

.item-edit, .item-delete {
  width: 44rpx;
  height: 44rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  text-align: center;
}

.item-desc {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
  text-align: center;
  line-height: 1.4;
}

.item-bottom {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-points {
  font-size: 28rpx;
  font-weight: bold;
  color: #4CAF50;
}

.item-points.punishment {
  color: #f44336;
}

.btn-action {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.btn-action.punishment {
  background: linear-gradient(135deg, #f44336, #e53935);
}

.btn-action[disabled] {
  background: #e0e0e0;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.add-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.add-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 16rpx;
  color: #fff;
}

.add-icon {
  font-size: 36rpx;
  font-weight: bold;
}

.add-text {
  font-size: 28rpx;
  font-weight: 500;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.record-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-right: 16rpx;
}

.record-first-line {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: block;
}

.record-type {
  font-weight: bold;
}

.record-type.reward {
  color: #4CAF50;
}

.record-type.violation {
  color: #f44336;
}

.record-text {
  font-size: 28rpx;
  color: #333;
}

.record-desc {
  font-size: 28rpx;
  color: #333;
}

.record-type {
  font-weight: bold;
}

.record-type.reward {
  color: #4CAF50;
}

.record-type.violation {
  color: #f44336;
}

.record-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.record-time {
  font-size: 22rpx;
  color: #999;
}

.type-tag {
  font-size: 22rpx;
  color: #4CAF50;
  font-weight: bold;
  margin-right: 8rpx;
}

.type-tag.violation {
  color: #f44336;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 24rpx;
}

.record-points {
  font-size: 32rpx;
  font-weight: bold;
  white-space: nowrap;
}

.record-points.reward {
  color: #4CAF50;
}

.record-points.violation {
  color: #f44336;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

.btn-cancel {
  flex: 1;
  padding: 24rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn-confirm {
  flex: 1;
  padding: 24rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  font-weight: bold;
}

.icon-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.selected-icon {
  font-size: 40rpx;
}

.icon-arrow {
  font-size: 32rpx;
  color: #999;
}

.icon-picker-content {
  max-height: 60vh;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.icon-option {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.icon-option.selected {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border: 3rpx solid #4CAF50;
}

.detail-content {
  max-height: 70vh;
}

.detail-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.detail-section:first-child {
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-icon {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.detail-points {
  font-size: 36rpx;
  font-weight: bold;
}

.detail-points.reward {
  color: #4CAF50;
}

.detail-points.violation {
  color: #f44336;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.stats-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.correct-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stats-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
}

.stats-value {
  font-size: 36rpx;
  font-weight: bold;
}

.stats-value.green {
  color: #4CAF50;
}

.stats-value.red {
  color: #f44336;
}

.stats-label {
  font-size: 22rpx;
  color: #999;
}

/* 小朋友列表样式 */
.child-list-content {
  max-height: 80vh;
}

.child-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.child-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  gap: 20rpx;
}

.child-item.active {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border: 2rpx solid #4CAF50;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  overflow: hidden;
}

.child-avatar .child-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.child-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.child-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.child-school {
  font-size: 24rpx;
  color: #999;
}

.child-actions {
  display: flex;
  gap: 12rpx;
}

.child-edit, .child-delete {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

/* 添加小朋友样式 */
.add-child-content {
  max-height: 85vh;
}

.avatar-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.preview-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  overflow: hidden;
}

.preview-avatar .preview-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.gender-picker {
  display: flex;
  gap: 16rpx;
}

.gender-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.gender-option.active {
  border-color: #4CAF50;
  background: #e8f5e9;
}

.gender-option text {
  font-size: 28rpx;
  color: #333;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.date-picker text:last-child {
  color: #999;
}

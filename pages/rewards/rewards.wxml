<view class="container">
  <!-- 积分卡片 -->
  <view class="card points-card">
    <text class="points-label">当前积分</text>
    <text class="points-value">{{userInfo.points}}</text>
    <view class="points-history" bindtap="goToHistory">
      <text>兑换记录</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 添加自定义礼物按钮 -->
  <view class="add-custom-btn" bindtap="showAddCustom">
    <text class="add-icon">+</text>
    <text class="add-text">添加自定义礼物</text>
  </view>

  <!-- 奖励列表 -->
  <view class="rewards-list">
    <block wx:for="{{rewards}}" wx:key="_id">
      <view class="reward-item">
        <view class="reward-image-wrapper">
          <view class="reward-emoji" wx:if="{{!item.image || item.image.startsWith('/images/') || item.image === 'custom'}}">
            {{item.isCustom ? '�' : '🎁'}}
          </view>
          <image class="reward-image" wx:else src="{{item.image}}" mode="aspectFill"></image>
          <view class="reward-badge" wx:if="{{item.stock < 20}}">剩余{{item.stock}}</view>
        </view>
        <view class="reward-content">
          <text class="reward-name">{{item.name}}</text>
          <text class="reward-desc">{{item.description}}</text>
          <view class="reward-bottom">
            <text class="reward-points">{{item.points}}积分</text>
            <button class="btn-exchange" bindtap="exchangeReward" data-id="{{item._id}}" data-points="{{item.points}}" disabled="{{userInfo.points < item.points || item.stock <= 0}}">
              {{userInfo.points >= item.points && item.stock > 0 ? '兑换' : '积分不足'}}
            </button>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 兑换记录弹窗 -->
  <view class="modal" wx:if="{{showHistory}}">
    <view class="modal-mask" bindtap="closeHistory"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text>兑换记录</text>
        <text class="close-btn" bindtap="closeHistory">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <block wx:for="{{exchangeRecords}}" wx:key="_id">
          <view class="record-item">
            <view class="record-info">
              <view class="record-emoji" wx:if="{{!item.rewardImage || item.rewardImage.startsWith('/images/') || item.rewardImage === 'custom'}}">🎁</view>
              <image wx:else src="{{item.rewardImage}}" mode="aspectFill"></image>
              <view class="record-text">
                <text class="record-name">{{item.rewardName}}</text>
                <text class="record-time">{{item.createTime}}</text>
              </view>
            </view>
            <text class="record-points">-{{item.pointsUsed}}积分</text>
          </view>
        </block>
        <view class="empty-history" wx:if="{{exchangeRecords.length === 0}}">
          <text>暂无兑换记录</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 添加自定义礼物弹窗 -->
  <view class="modal" wx:if="{{showAddCustomModal}}">
    <view class="modal-mask" bindtap="closeAddCustom"></view>
    <view class="modal-content add-custom-modal">
      <view class="modal-header">
        <text>添加自定义礼物</text>
        <text class="close-btn" bindtap="closeAddCustom">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">礼物名称 *</text>
          <input class="form-input" placeholder="例如：冰淇淋、看电影" value="{{customGift.name}}" bindinput="onCustomNameInput" />
        </view>
        <view class="form-item">
          <text class="form-label">所需积分 *</text>
          <input class="form-input" type="number" placeholder="例如：50" value="{{customGift.points}}" bindinput="onCustomPointsInput" />
        </view>
        <view class="form-item">
          <text class="form-label">礼物描述</text>
          <textarea class="form-textarea" placeholder="描述这个礼物..." value="{{customGift.description}}" bindinput="onCustomDescInput" />
        </view>
        <view class="form-item">
          <text class="form-label">礼物图片</text>
          <view class="image-picker" bindtap="chooseCustomImage">
            <image wx:if="{{customGift.image}}" src="{{customGift.image}}" mode="aspectFill"></image>
            <view wx:else class="image-placeholder">
              <text class="placeholder-icon">📷</text>
              <text class="placeholder-text">点击选择图片</text>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeAddCustom">取消</button>
        <button class="btn-confirm" bindtap="saveCustomGift">保存</button>
      </view>
    </view>
  </view>
</view>

/* 页面滚动容器 */
page {
  height: auto;
  min-height: 100vh;
  background: #f5f5f5;
}

.container.dark-mode {
  min-height: 100vh;
  background: #121212;
  padding: 24rpx;
  box-sizing: border-box;
}

.dark-mode .poster-wrapper {
  background: #1e1e1e;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.dark-mode .btn-back {
  background: #2c2c2c;
  color: #e0e0e0;
}

.dark-mode .tip {
  color: #888888;
}

.poster-wrapper {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.poster-canvas {
  width: 100%;
  height: 0;
}

.poster-preview {
  width: 100%;
  display: block;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 40rpx;
}

.actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.btn-save {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
}

.btn-share {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: #fff;
}

.btn-back {
  background: #f5f5f5;
  color: #333;
}

.btn-icon {
  font-size: 36rpx;
}

.tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}

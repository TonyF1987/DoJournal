<view class="container">
  <!-- 顶部区域 -->
  <view class="top-header">
    <view class="header-content">
        <view class="user-info">
          <text class="user-name">{{userInfo.nickName || '小宝贝'}}</text>
          <text class="header-slogan">坚持每天完成作业，养成学习好习惯</text>
        </view>
      </view>
    <view class="header-stats">
      <view class="stat-item">
        <text class="stat-value">{{userInfo.points}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">🔥 {{userInfo.streak}}</text>
        <text class="stat-label">连续打卡</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{completedToday}}</text>
        <text class="stat-label">今日完成</text>
      </view>
    </view>
  </view>

  <!-- 日历区域 -->
  <view class="section calendar-section">
    <view class="calendar-header">
      <view class="month-nav">
        <text class="nav-btn" bindtap="prevMonth">‹</text>
        <text class="month-title">{{currentYear}}年{{currentMonth + 1}}月</text>
        <text class="nav-btn" bindtap="nextMonth">›</text>
      </view>
    </view>
    <view class="calendar">
      <view class="calendar-weekdays">
        <text class="weekday">一</text>
        <text class="weekday">二</text>
        <text class="weekday">三</text>
        <text class="weekday">四</text>
        <text class="weekday">五</text>
        <text class="weekday">六</text>
        <text class="weekday">日</text>
      </view>
      <view class="calendar-days">
        <block wx:for="{{calendarData}}" wx:key="index">
          <view class="calendar-day {{item.isCurrentMonth ? 'current-month' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.hasHomework ? 'has-homework' : ''}} {{item.hasPendingHomework && !item.allCompleted ? 'has-pending' : ''}} {{item.allCompleted ? 'all-completed' : ''}} {{item.isSelected ? 'selected' : ''}}" bindtap="onDateTap" data-date="{{item}}">
            <text class="day-count" wx:if="{{item.homeworkCount > 0 && !item.allCompleted}}">{{item.homeworkCount}}</text>
            <text class="day-text">{{item.day}}</text>
            <text class="day-check" wx:if="{{item.allCompleted}}">✓</text>
          </view>
        </block>
      </view>
      <view class="calendar-toggle" bindtap="toggleCalendarExpand">
        <text>{{calendarExpanded ? '收起日历' : '展开完整日历'}}</text>
      </view>
    </view>
  </view>

  <!-- 作业区域 -->
  <view class="section homework-section">
    <view class="homework-header">
      <text class="homework-title">{{formattedSelectedDate}} 作业</text>
      <view class="homework-actions">
        <text class="action-btn" bindtap="copyHomework">复制</text>
        <text class="action-btn" bindtap="editDayHomework">编辑</text>
      </view>
    </view>
    
    <!-- 科目标签栏 -->
    <view class="subject-tabs-container">
      <scroll-view class="subject-tabs" scroll-x="true" show-scrollbar="false">
        <block wx:for="{{subjects}}" wx:key="_id">
          <view class="tab-item {{selectedSubject === item.name ? 'active' : ''}}" bindtap="selectSubject" data-subject="{{item.name}}">
            <text class="tab-status pending" wx:if="{{subjectStatusMap[item.name] === 'pending'}}">未完成</text>
            <text class="tab-check completed" wx:if="{{subjectStatusMap[item.name] === 'completed'}}">✓</text>
            <text class="tab-text">{{item.name}}</text>
        </view>
        </block>
        <view class="add-subject-btn" bindtap="goToAddSubject">
          <text>+</text>
        </view>
      </scroll-view>
    </view>
    
    <!-- 作业列表 -->
    <view class="homework-list" wx:if="{{subjectHomework.length > 0}}">
      <block wx:for="{{subjectHomework}}" wx:key="_id">
        <view class="homework-card {{item.status === 'completed' ? 'done' : ''}}">
          <view class="card-left" catchtap="toggleCheckIn" data-id="{{item._id}}" data-status="{{item.status}}">
            <view wx:if="{{item.status === 'completed'}}" class="done-icon-left">✓</view>
            <view wx:else class="check-circle"></view>
          </view>
          <view class="card-content">
            <view class="card-content-row">
              <text class="card-desc">{{item.content}}</text>
              <view class="points-tag {{item.status === 'completed' ? 'done' : ''}}">
                <text wx:if="{{item.actualPoints && item.basePoints}}">{{item.actualPoints}}分 ({{item.ratingPercent || 100}}%)</text>
                <text wx:else>+{{item.points}}分</text>
              </view>
            </view>
            <view class="card-footer">
              <view class="card-meta" wx:if="{{item.status !== 'completed'}}">
                <text class="meta-tag recurring" wx:if="{{item.recurring}}">🔄 {{item.recurringDaysText}}</text>
                <text class="meta-time" wx:else>创建于{{item.createTime}}</text>
              </view>
              <text class="done-time" wx:if="{{item.status === 'completed'}}">完成时间：{{item.checkInTime}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
    
    <view class="empty-state" wx:if="{{subjectHomework.length === 0}}">
      <text class="empty-icon">📚</text>
      <text class="empty-text">该科目暂无作业</text>
      <text class="empty-sub">点击右上角添加作业</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="goToAdd">
    <text>+</text>
  </view>
</view>

<!-- 复制作业日期选择器（隐藏） -->
<picker 
  id="copyDatePicker"
  mode="date" 
  value="{{copySelectedDate || selectedDate}}" 
  fields="day" 
  bindchange="onCopyDateChange"
>
</picker>

<!-- 复制用日历弹窗（和参考设计一致） -->
<view class="modal copy-calendar-full-modal" wx:if="{{showCopyCalendar}}">
  <view class="copy-calendar-popup">
    <!-- 头部：导航和关闭 -->
    <view class="copy-calendar-header">
      <text class="copy-calendar-arrow" bindtap="prevCopyMonth">‹</text>
      <text class="copy-calendar-month">{{copyCalendarYear}}年{{copyCalendarMonth + 1}}月</text>
      <text class="copy-calendar-arrow copy-calendar-arrow-right" bindtap="nextCopyMonth">›</text>
      <text class="copy-calendar-close" bindtap="toggleCopyCalendar">×</text>
    </view>
    
    <!-- 星期头部 -->
    <view class="copy-calendar-week-header">
      <text class="copy-week-item" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</text>
    </view>
    
    <!-- 日期格子 -->
      <view class="copy-calendar-dates">
        <view 
          class="copy-date-item {{!item.isCurrentMonth ? 'copy-date-disabled' : ''}} {{ (tempSelectedDate == item.fullDate || (tempSelectedDate && tempSelectedDate == item.date)) ? 'copy-date-selected' : ''}}"
          wx:for="{{copyCalendarData}}" 
          wx:key="index"
          catchtap="selectTempDate"
          data-date="{{item}}"
        >
          <text class="copy-date-text">{{item.day}}</text>
          <text wx:if="{{item.hasPendingHomework && item.isCurrentMonth}}" class="copy-date-dot"></text>
        </view>
      </view>
    
    <!-- 底部确认按钮 -->
    <view class="copy-calendar-footer">
      <button class="copy-confirm-btn" bindtap="confirmSelectedDate">确认</button>
    </view>
  </view>
</view>

<!-- 复制作业弹窗 -->
<view class="modal copy-modal-container" wx:if="{{showCopyModal}}">
  <view class="modal-mask" bindtap="closeCopyModal"></view>
  <view class="copy-modal-content">
    <!-- 头部标题 -->
    <view class="copy-modal-header">
      <text class="copy-modal-title">复制作业</text>
      <text class="copy-modal-close" bindtap="closeCopyModal">×</text>
    </view>
    
    <!-- 内容区域 -->
    <view class="copy-modal-body">
      <view class="copy-tip-text">将{{userInfo.nickName || '用户'}}{{formattedSelectedDate}}的作业复制到:</view>
      
      <!-- 日期选择框 -->
      <view class="copy-date-input" catchtap="toggleCopyCalendar">
        <text class="copy-date-text-input {{copySelectedDate ? 'copy-date-selected' : ''}}">{{copySelectedDate || '请选择日期'}}</text>
        <text class="copy-date-arrow">›</text>
      </view>
      
      <view class="copy-subject-title">选择要复制的作业科目:</view>
      
      <!-- 科目多选 -->
      <view class="copy-subject-list">
        <view 
          class="copy-subject-item" 
          wx:for="{{copyAvailableSubjects}}" 
          wx:key="name"
          catchtap="toggleCopySubject"
          data-subject="{{item.name}}"
          style="z-index: 10; position: relative;"
        >
          <view class="copy-checkbox {{item.checked ? 'copy-checkbox-checked' : ''}}" style="pointer-events: none;">
            <text wx:if="{{item.checked}}" class="copy-checkbox-check">✓</text>
          </view>
          <text class="copy-subject-name" style="pointer-events: none;">{{item.name}}</text>
        </view>
      </view>
    </view>
    
    <!-- 底部按钮 -->
    <view class="copy-modal-footer">
      <button class="copy-btn copy-btn-cancel" bindtap="closeCopyModal">取消</button>
      <button class="copy-btn copy-btn-confirm" bindtap="confirmCopy">确定</button>
    </view>
  </view>
</view>

<!-- 科目管理弹窗 -->
<view class="modal" wx:if="{{showSubjectManageModal}}">
  <view class="modal-mask" bindtap="closeSubjectManageModal"></view>
  <view class="modal-content subject-manage-modal">
    <view class="modal-header">
      <text>科目管理</text>
      <text class="close-btn" bindtap="closeSubjectManageModal">×</text>
    </view>
    <scroll-view class="modal-body" scroll-y>
        <block wx:for="{{subjects}}" wx:key="_id">
          <view class="subject-manage-item">
            <view class="subject-sort">
              <text class="sort-btn up {{index === 0 ? 'disabled' : ''}}" bindtap="{{index === 0 ? '' : 'moveSubjectUp'}}" data-subject="{{item}}" data-index="{{index}}">↑</text>
              <text class="sort-btn down {{index === subjects.length - 1 ? 'disabled' : ''}}" bindtap="{{index === subjects.length - 1 ? '' : 'moveSubjectDown'}}" data-subject="{{item}}" data-index="{{index}}">↓</text>
            </view>
            <view class="subject-info">
              <view class="subject-color" style="background-color: {{item.color}}"></view>
              <text class="subject-name">{{item.name}}</text>
            </view>
            <view class="subject-actions">
              <text class="action-btn edit" bindtap="showEditSubjectModal" data-subject="{{item}}">编辑</text>
              <text class="action-btn delete" bindtap="deleteSubject" data-subject="{{item}}">删除</text>
            </view>
          </view>
        </block>
      <view wx:if="{{subjects.length === 0}}" class="empty-subjects">
        <text>暂无科目，点击下方按钮添加</text>
      </view>
    </scroll-view>
    <view class="modal-footer">
      <button class="btn-add-subject" bindtap="showAddSubjectModal">添加新科目</button>
    </view>
  </view>
</view>

<!-- 添加科目弹窗 -->
<view class="modal" wx:if="{{showAddSubjectModal}}">
  <view class="modal-mask" bindtap="closeAddSubjectModal"></view>
  <view class="modal-content add-subject-modal">
    <view class="modal-header">
      <text>添加新科目</text>
      <text class="close-btn" bindtap="closeAddSubjectModal">×</text>
    </view>
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">科目名称 *</text>
        <input class="form-input" placeholder="例如：数学、英语" value="{{newSubjectName}}" bindinput="onNewSubjectInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeAddSubjectModal">取消</button>
      <button class="btn-confirm" bindtap="addSubject">确定</button>
    </view>
  </view>
</view>

<!-- 编辑科目弹窗 -->
<view class="modal" wx:if="{{showEditSubjectModal}}">
  <view class="modal-mask" bindtap="closeEditSubjectModal"></view>
  <view class="modal-content edit-subject-modal">
    <view class="modal-header">
      <text>编辑科目</text>
      <text class="close-btn" bindtap="closeEditSubjectModal">×</text>
    </view>
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">科目名称 *</text>
        <input class="form-input" placeholder="例如：数学、英语" value="{{editingSubjectName}}" bindinput="onEditSubjectInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeEditSubjectModal">取消</button>
      <button class="btn-confirm" bindtap="updateSubject">确定</button>
    </view>
  </view>
</view>

<view class="checkin-modal" wx:if="{{showCheckinModal}}">
  <view class="checkin-mask" bindtap="closeCheckinModal"></view>
  <view class="checkin-popup">
    <view class="checkin-popup-header">
      <text class="checkin-popup-title">打卡</text>
      <text class="checkin-close" bindtap="closeCheckinModal">×</text>
    </view>
    
    <view class="checkin-popup-body">
      <view class="checkin-homework-info" wx:if="{{checkinHomework}}">
        <text class="checkin-homework-content">{{checkinHomework.content}}</text>
        <text class="checkin-homework-points">+{{checkinHomework.points}}分</text>
      </view>

      <view class="checkin-section">
        <view class="checkin-section-header">
          <text class="checkin-section-label">上传凭证</text>
          <text class="checkin-section-optional">（可选）</text>
        </view>
        <view class="checkin-upload">
          <view class="checkin-upload-preview" wx:if="{{checkinProofImage}}" bindtap="chooseCheckinImage">
            <image src="{{checkinProofImage}}" mode="aspectFill"></image>
            <view class="checkin-upload-delete" catchtap="deleteCheckinImage">×</view>
          </view>
          <view class="checkin-upload-btn" wx:else bindtap="chooseCheckinImage">
            <text class="checkin-upload-icon">📷</text>
            <text class="checkin-upload-text">拍照或相册</text>
          </view>
        </view>
      </view>

      <view class="checkin-section">
        <view class="checkin-section-header">
          <text class="checkin-section-label">完成质量</text>
          <text class="checkin-section-optional">（可选）</text>
        </view>
        <view class="checkin-rating">
          <view class="checkin-rating-item {{checkinRating === 3 ? 'active' : ''}}" bindtap="selectCheckinRating" data-rating="3">
            <text class="checkin-rating-stars">⭐⭐⭐</text>
            <text class="checkin-rating-label">优秀</text>
            <text class="checkin-rating-percent">100%</text>
          </view>
          <view class="checkin-rating-item {{checkinRating === 2 ? 'active' : ''}}" bindtap="selectCheckinRating" data-rating="2">
            <text class="checkin-rating-stars">⭐⭐</text>
            <text class="checkin-rating-label">良好</text>
            <text class="checkin-rating-percent">80%</text>
          </view>
          <view class="checkin-rating-item {{checkinRating === 1 ? 'active' : ''}}" bindtap="selectCheckinRating" data-rating="1">
            <text class="checkin-rating-stars">⭐</text>
            <text class="checkin-rating-label">合格</text>
            <text class="checkin-rating-percent">60%</text>
          </view>
        </view>
      </view>

      <view class="checkin-section">
        <view class="checkin-section-header">
          <text class="checkin-section-label">打卡评语</text>
          <text class="checkin-section-optional">（可选）</text>
        </view>
        <textarea class="checkin-comment" placeholder="记录完成心得..." value="{{checkinComment}}" bindinput="onCheckinCommentInput" maxlength="200"></textarea>
      </view>
    </view>

    <view class="checkin-popup-footer">
      <button class="checkin-btn-quick" bindtap="quickCheckin">快速打卡</button>
      <button class="checkin-btn-submit" bindtap="submitCheckinWithProof" wx:if="{{checkinProofImage}}">提交打卡</button>
    </view>
  </view>
</view>

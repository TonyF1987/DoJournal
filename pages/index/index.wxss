page {
  background: linear-gradient(180deg, #f0f7f0 0%, #f5f5f5 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.container {
  padding: 24rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.3);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  margin-right: 24rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 4rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 区块样式 */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.count-badge {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  min-width: 40rpx;
  text-align: center;
}

.count-badge.completed {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
}

/* 任务列表 */
.homework-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.homework-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  flex: 1 1 calc(50% - 10rpx);
  min-width: 300rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.homework-card:active {
  transform: scale(0.98);
  border-color: #4CAF50;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.points-tag {
  background: linear-gradient(135deg, #FFD700, #FFC107);
  color: #8B6914;
  font-size: 22rpx;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.card-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
  min-height: 72rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.meta-tag {
  font-size: 20rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meta-tag.recurring {
  color: #2196F3;
  background: rgba(33, 150, 243, 0.1);
}

.meta-time {
  font-size: 22rpx;
  color: #bbb;
}

.checkin-btn {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 已完成样式 */
.homework-card.done {
  background: #fafafa;
  border: 2rpx solid #eee;
}

.homework-card.done .card-title {
  color: #999;
}

.homework-card.done .card-desc {
  color: #bbb;
}

.points-tag.done {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
}

.done-icon-small {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.done-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.done-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.empty-state.small {
  padding: 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.add-btn text {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.add-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.4);
}

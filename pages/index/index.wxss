page {
  background: linear-gradient(180deg, #f0f7f0 0%, #f5f5f5 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
  max-width: 100%;
  overflow-x: hidden;
}

/* 顶部区域 */
.top-header {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  padding: 30rpx 24rpx 40rpx;
  margin: -24rpx -24rpx 32rpx;
  position: relative;
  overflow: hidden;
}

/* 家庭/用户信息 */
.family-info-section {
  margin-bottom: 20rpx;
}

.parent-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
}

.parent-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.parent-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.parent-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.family-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.family-icon {
  font-size: 20rpx;
}

.family-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.family-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 4rpx;
}

/* 小朋友卡片 */
.child-info-section {
  margin-bottom: 24rpx;
}

.child-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.child-card-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e3f2fd, #bbdefb);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  overflow: hidden;
}

.child-card-avatar .child-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.child-card-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.child-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.child-card-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.child-card-switch {
  font-size: 24rpx;
  color: #4CAF50;
}

.child-card-meta {
  display: flex;
  align-items: center;
}

.child-card-school {
  font-size: 24rpx;
  color: #999;
}

/* 家庭成员快速预览 */
.family-members-preview {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50rpx;
  align-self: flex-start;
}

.members-list {
  display: flex;
}

.member-preview-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.6);
  margin-left: -12rpx;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.member-preview-avatar:first-child {
  margin-left: 0;
}

.members-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 8rpx;
}

.header-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  min-height: 80rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

/* 区块样式 */
.section {
  margin-bottom: 32rpx;
}

.section:last-child {
  margin-bottom: 120rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.count-badge {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  min-width: 40rpx;
  text-align: center;
}

.count-badge.completed {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
}

.subject-count {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

/* 作业区域 */
.homework-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.homework-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.homework-actions {
  display: flex;
  gap: 32rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #FFA726;
  font-weight: 600;
}

/* 科目标签栏 */
.subject-tabs-container {
  margin-bottom: 32rpx;
}

.subject-tabs {
  white-space: nowrap;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 32rpx 48rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #fafafa, #f0f0f0);
  border-radius: 60rpx;
  position: relative;
  min-width: 80rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item:active {
  transform: scale(0.96);
}

.tab-item.active {
  background: linear-gradient(135deg, #FF9800, #FFA726);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.tab-status {
  position: absolute;
  top: -8rpx;
  right: 8rpx;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  color: #fff;
  z-index: 10;
}

.tab-status.pending {
  background: #FF5252;
}

.tab-check.completed {
  position: absolute;
  top: -8rpx;
  left: 8rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
  background: #4CAF50;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.tab-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #666;
}

.tab-item.active .tab-text {
  color: #fff;
  font-weight: bold;
}

.add-subject-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  flex-shrink: 0;
  font-weight: bold;
  position: relative;
  z-index: 10;
  margin-left: 16rpx;
  margin-right: 20rpx;
  vertical-align: middle;
  display: inline-flex;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.add-subject-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}



/* 任务列表 */
.homework-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.homework-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  flex: 1 1 100%;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  overflow: hidden;
}

.card-left {
  flex-shrink: 0;
  display: flex;
  align-items: flex-start;
  padding-top: 4rpx;
}

.done-icon-left {
  width: 48rpx;
  height: 48rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.check-circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  background: #fff;
  transition: all 0.3s ease;
}

.check-circle:active {
  background: rgba(76, 175, 80, 0.1);
  border-color: #4CAF50;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.homework-card:active {
  transform: scale(0.98);
  border-color: #4CAF50;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.points-tag {
  background: linear-gradient(135deg, #FFD700, #FFC107);
  color: #8B6914;
  font-size: 22rpx;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.card-desc-wrapper {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  min-height: 72rpx;
}

.card-content-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
  min-height: 72rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
  margin-right: 16rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.meta-tag {
  font-size: 20rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meta-tag.recurring {
  color: #2196F3;
  background: rgba(33, 150, 243, 0.1);
}

.meta-time {
  font-size: 22rpx;
  color: #bbb;
}

.checkin-btn {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 已完成样式 */
.homework-card.done {
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  opacity: 0.8;
}

.homework-card.done .card-title {
  color: #6c757d;
  text-decoration: line-through;
}

.homework-card.done .card-desc {
  color: #adb5bd;
}

.points-tag.done {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
}

.done-icon-small {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.done-time {
  font-size: 22rpx;
  color: #6c757d;
  flex: 1;
}

.done-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.done-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.empty-state.small {
  padding: 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.add-btn text {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.add-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.4);
}

/* 日历样式 */
.calendar-section {
  margin-top: -48rpx;
  position: relative;
  z-index: 10;
}

.calendar-header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.nav-btn {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  width: 60rpx;
  height: 60rpx;
  text-align: center;
  line-height: 60rpx;
  flex-shrink: 0;
}

.month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  min-width: 200rpx;
  text-align: center;
  flex-shrink: 0;
}



.calendar {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 20rpx;
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  padding: 12rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-bottom: 12rpx;
  padding: 0 4rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  position: relative;
  background: #f5f5f5;
  width: 100%;
  max-width: 80rpx;
  margin: 0 auto;
}

.day-count {
  position: absolute;
  top: -6rpx;
  font-size: 16rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 50%;
  width: 24rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  font-weight: bold;
  z-index: 2;
}

.day-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

.calendar-day.other-month .day-text {
  color: #ccc;
}

.calendar-day.current-month .day-text {
  color: #333;
}

.calendar-day.today {
  background: rgba(76, 175, 80, 0.3);
  border: 2rpx solid #4CAF50;
}

.calendar-day.today .day-text {
  color: #4CAF50;
  font-weight: bold;
}

.calendar-day.has-homework {
  background: rgba(76, 175, 80, 0.1);
}

.calendar-day.has-pending {
  background: rgba(255, 107, 107, 0.1);
}

.calendar-day.selected {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  transform: scale(1.05);
  z-index: 10;
}

.calendar-day.selected .day-text {
  color: #fff;
  font-weight: bold;
}

.day-check {
  position: absolute;
  bottom: -4rpx;
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 900;
  z-index: 2;
  text-shadow: 0 1rpx 2rpx rgba(76, 175, 80, 0.3);
}

.calendar-day.all-completed {
  background: rgba(76, 175, 80, 0.2);
}

.calendar-day.all-completed.has-pending {
  background: rgba(76, 175, 80, 0.2);
}

.calendar-toggle {
  text-align: center;
  padding: 16rpx 0 8rpx;
  border-top: 1rpx solid #f0f0f0;
}

.calendar-toggle text {
  font-size: 24rpx;
  color: #999;
}

/* 横向滚动日历 */
.calendar-scroll {
  width: 100%;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.calendar-scroll-inner {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
  width: max-content;
}

.calendar-scroll-item {
  width: 80rpx;
  min-width: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.2s;
  flex-shrink: 0;
}

.calendar-scroll-item.today {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
}

.calendar-scroll-item.today .scroll-weekday,
.calendar-scroll-item.today .scroll-day {
  color: #fff;
}

.calendar-scroll-item.selected {
  background: linear-gradient(135deg, #66BB6A, #81C784);
  transform: scale(1.05);
}

.calendar-scroll-item.selected .scroll-weekday,
.calendar-scroll-item.selected .scroll-day {
  color: #fff;
}

.calendar-scroll-item.has-homework {
  background: #f5f5f5;
}

.calendar-scroll-item.has-pending {
  background: rgba(255, 193, 7, 0.15);
}

.calendar-scroll-item.all-completed {
  background: rgba(76, 175, 80, 0.2);
}

.scroll-weekday {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.scroll-day {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.scroll-month {
  font-size: 16rpx;
  color: #4CAF50;
  margin-top: 2rpx;
}

/* 弹窗通用样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 科目管理弹窗 */
.subject-manage-modal .modal-body {
  padding: 0;
}

.subject-manage-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.subject-sort {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
}

.sort-btn {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 4rpx;
  font-size: 20rpx;
  color: #666;
}

.sort-btn:active {
  background: #e0e0e0;
}

.sort-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.subject-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.subject-color {

.member-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.member-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.member-role {
  font-size: 22rpx;
  color: #999;
}

.family-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.family-empty-state {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.family-empty-state .empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 16rpx;
}

.family-empty-state .empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
}

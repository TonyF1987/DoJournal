/* 复制用日历弹窗 - 底部弹出样式 */
.copy-calendar-full-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999999 !important; /* 层级最高，覆盖所有元素包括tab */
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: flex-end;
  padding: 0; /* 去掉所有内边距，让弹窗占满底部 */
  margin: 0;
}

.copy-calendar-popup {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 20rpx 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); /* 只留安全区距离 */
  box-sizing: border-box;
  min-height: 60vh; /* 缩小弹窗高度 */
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000000 !important;
}

/* 头部 */
.copy-calendar-header {
  display: flex;
  align-items: center;
  justify-content: center; /* 居中对齐 */
  margin-bottom: 16rpx;
  position: relative;
  padding: 0 10rpx; /* 调整左右padding */
}

.copy-calendar-arrow {
  font-size: 40rpx;
  color: #666;
  width: 60rpx; /* 调整箭头宽度 */
  text-align: center;
  z-index: 100; /* 层级比标题高，不会被挡住 */
  pointer-events: auto;
  flex-shrink: 0; /* 防止被压缩 */
}

.copy-calendar-arrow-right {
  /* 右边箭头不需要额外样式 */
}

.copy-calendar-month {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  z-index: 50;
  pointer-events: none; /* 标题不接收点击事件，点击箭头区域直接触发箭头事件 */
  white-space: nowrap; /* 不换行 */
  padding: 0 20rpx; /* 增加标题左右间距，让箭头更靠近 */
  flex-shrink: 0; /* 防止被压缩 */
}

.copy-calendar-close {
  font-size: 40rpx;
  color: #666;
  width: 60rpx; /* 调整关闭按钮宽度 */
  text-align: center;
  z-index: 100;
  pointer-events: auto;
  flex-shrink: 0; /* 防止被压缩 */
  position: absolute; /* 绝对定位到右边 */
  right: 10rpx;
}

/* 星期 */
.copy-calendar-week-header {
  display: flex;
  margin-bottom: 12rpx;
}

.copy-calendar-week-header .copy-week-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

/* 日期 */
.copy-calendar-dates {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
  min-height: 420rpx; /* 缩小高度 */
  height: auto;
}

.copy-date-item {
  width: 14.28%;
  padding: 4rpx 0; /* 缩小上下间距，行更紧凑 */
  text-align: center;
  position: relative;
  z-index: 50;
  pointer-events: auto;
}

.copy-date-text {
  width: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 50%;
  display: inline-block;
  font-size: 28rpx;
  color: #333;
  z-index: 20;
  position: relative;
  pointer-events: none;
}

/* 日历中选中日期的高亮样式 */
.copy-date-selected .copy-date-text {
  background: #4CAF50 !important;
  color: #fff !important;
  font-weight: bold !important;
}

.copy-date-disabled .copy-date-text {
  color: #ccc;
  opacity: 0.6;
}

/* 日期选择显示框，确保文字完整显示 */
.copy-date-text-input {
  font-size: 28rpx;
  color: #999;
  white-space: nowrap;
  overflow: visible;
  width: auto;
  flex: 1;
}

.copy-date-text-input.copy-date-selected {
  color: #333;
}

.copy-date-dot {
  position: absolute;
  bottom: 5rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  background: #f43f3f;
  border-radius: 50%;
  z-index: 30;
}


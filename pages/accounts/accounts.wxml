<view class="container">
  <!-- 标题提示 -->
  <view class="tips-section" wx:if="{{isCreator || !hasFamily}}">
    <text class="tips-text">您可以使用不同的账号登录，每个账号都是独立的，但可以加入同一个家庭</text>
  </view>

  <!-- 非创建者提示 -->
  <view class="tips-section warning-tips" wx:if="{{hasFamily && !isCreator}}">
    <text class="tips-text">当前账号不是家庭创建者，只能查看和使用当前账号</text>
  </view>

  <!-- 账号列表 -->
  <view class="accounts-section">
    <view class="section-header">
      <text class="section-title">我的账号</text>
    </view>
    
    <view class="accounts-list">
      <block wx:for="{{accounts}}" wx:key="_id">
        <view class="account-item {{currentAccountId === item._id ? 'active' : ''}}" 
              bindtap="{{(isCreator || !hasFamily) ? 'switchAccount' : ''}}" 
              data-account="{{item}}"
              style="{{!(isCreator || !hasFamily) ? 'cursor: default;' : ''}}">
          <view class="account-avatar">
            <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="account-avatar-img" />
            <text wx:else>👤</text>
          </view>
          <view class="account-info">
            <text class="account-name">{{item.nickName || '微信用户'}}</text>
            <view class="account-meta">
              <text wx:if="{{item.account}}" class="account-tag">{{item.account}}</text>
              <text wx:elif="{{item.phoneNumber}}" class="account-tag">{{item.phoneNumber}}</text>
              <text wx:else class="account-tag">微信账号</text>
            </view>
            <view class="account-badges" wx:if="{{item.familyRole || item.readOnly}}">
              <text class="member-role" wx:if="{{item.familyRole === 'creator'}}">创建者</text>
              <text class="member-role" wx:elif="{{item.familyRole === 'admin'}}">管理员</text>
              <text class="member-role member-readonly" wx:if="{{item.readOnly}}">只读</text>
            </view>
          </view>
          <view wx:if="{{currentAccountId === item._id}}" class="account-status">
            <text class="status-text">当前使用</text>
          </view>
          <view wx:elif="{{(isCreator || !hasFamily)}}" class="account-arrow">›</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 添加新账号 -->
  <view class="add-account-section" wx:if="{{isCreator || !hasFamily}}">
    <view class="add-account-btn" bindtap="goToAddAccount">
      <text class="add-icon">+</text>
      <text class="add-text">添加新账号</text>
    </view>
  </view>

  <!-- 编辑资料入口 -->
  <view class="edit-profile-section">
    <view class="menu-item" bindtap="openEditProfile">
      <view class="menu-icon-wrapper">
        <text class="menu-icon">✏️</text>
      </view>
      <view class="menu-content">
        <text class="menu-title">编辑当前账号资料</text>
        <text class="menu-desc">修改昵称和头像</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>

<!-- 编辑资料弹窗 -->
<view class="modal" wx:if="{{showEditProfile}}" bindtap="closeEditProfile">
  <view class="modal-mask"></view>
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text>编辑资料</text>
      <text class="close-btn" bindtap="closeEditProfile">×</text>
    </view>
    <view class="modal-body">
      <view class="edit-avatar-section">
        <view class="edit-avatar" bindtap="chooseAvatar">
          <image wx:if="{{editUserInfo.avatarUrl}}" src="{{editUserInfo.avatarUrl}}" mode="aspectFill" class="edit-avatar-img" />
          <text wx:else class="edit-avatar-placeholder">📷</text>
          <view class="avatar-edit-badge">更换头像</view>
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">昵称</text>
        <input class="form-input" placeholder="请输入昵称" value="{{editUserInfo.nickName}}" bindinput="onNickNameInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeEditProfile">取消</button>
      <button class="btn-confirm" bindtap="saveProfile">保存</button>
    </view>
  </view>
</view>

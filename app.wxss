@import './styles/dark-theme.wxss';

/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  color: #333;
  box-sizing: border-box;
  max-width: 100vw;
  overflow-x: hidden;
}

/* ==================== 全局深色模式 ==================== */
page.dark-mode {
  background-color: #121212;
  color: #fff;
}

.dark-mode .card {
  background: #1E1E1E;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
}

.dark-mode .btn-secondary {
  background-color: #1E1E1E;
  color: #9eb0a0;
  border-color: rgba(143, 168, 146, 0.35);
}

.dark-mode .text-secondary {
  color: #999;
}

.dark-mode .container {
  background: #121212;
}

.dark-mode .scroll-container {
  background: #121212;
}

/* 全局深色模式强制覆盖 */
.dark-mode .user-card {
  background: #1E1E1E;
}

.dark-mode .user-name {
  color: #fff;
}

.dark-mode .user-desc {
  color: #999;
}

.dark-mode .user-avatar {
  background: #333;
}

.dark-mode .user-info {
  color: #fff;
}

.dark-mode .stats-card {
  background: #1E1E1E;
}

.dark-mode .stat-value {
  color: #fff;
}

.dark-mode .stat-label {
  color: #999;
}

.dark-mode .list-item {
  background: #1E1E1E;
}

.dark-mode .list-name {
  color: #fff;
}

.dark-mode .list-desc {
  color: #999;
}

.dark-mode .list-points {
  color: #9eb0a0;
}

.dark-mode .tab-bar {
  background: #1E1E1E;
  border-top-color: #333;
}

.dark-mode .tab-item {
  color: #999;
}

.dark-mode .tab-item.active {
  color: #c5d8c7;
}

.dark-mode .tabs-section {
  background: #1E1E1E;
}

.dark-mode .list-section {
  background: #121212;
}

.dark-mode .add-section {
  background: #1E1E1E;
}

/* top-header / btn-primary：见 styles/dark-theme.wxss */

/* 通用白色背景强制变为深色 */
.dark-mode .user-card,
.dark-mode .child-card,
.dark-mode .stats-card,
.dark-mode .list-item,
.dark-mode .grid-item,
.dark-mode .reward-item,
.dark-mode .violation-item,
.dark-mode .record-item,
.dark-mode .homework-item {
  background-color: #1E1E1E;
}

/* 通用文本颜色适配 */
.dark-mode .user-name,
.dark-mode .child-name,
.dark-mode .list-name,
.dark-mode .grid-name,
.dark-mode .reward-name,
.dark-mode .violation-name,
.dark-mode .record-name,
.dark-mode .homework-title,
.dark-mode .stat-value {
  color: #fff;
}

.dark-mode .user-desc,
.dark-mode .child-desc,
.dark-mode .list-desc,
.dark-mode .grid-desc,
.dark-mode .reward-desc,
.dark-mode .violation-desc,
.dark-mode .record-desc,
.dark-mode .homework-content,
.dark-mode .homework-time,
.dark-mode .stat-label {
  color: #999;
}

/* 通用积分颜色 */
.dark-mode .list-points,
.dark-mode .grid-points,
.dark-mode .reward-points,
.dark-mode .homework-points {
  color: #9eb0a0;
}

.dark-mode .list-points.negative,
.dark-mode .grid-points.negative,
.dark-mode .violation-points {
  color: #FF8A80;
}

/* 通用顶部和区域背景 - 见 dark-theme.wxss */

.dark-mode .tabs-section,
.dark-mode .list-section,
.dark-mode .add-section,
.dark-mode .content-area {
  background-color: #121212;
}

image {
  max-width: 100%;
  height: auto;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-secondary {
  background-color: #fff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
}

.points-badge {
  display: inline-block;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.text-primary {
  color: #4CAF50;
}

.text-secondary {
  color: #999;
}

.text-large {
  font-size: 36rpx;
  font-weight: bold;
}

.text-medium {
  font-size: 28rpx;
}

.text-small {
  font-size: 24rpx;
}

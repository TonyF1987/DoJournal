/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  color: #333;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-secondary {
  background-color: #fff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
}

.points-badge {
  display: inline-block;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.text-primary {
  color: #4CAF50;
}

.text-secondary {
  color: #999;
}

.text-large {
  font-size: 36rpx;
  font-weight: bold;
}

.text-medium {
  font-size: 28rpx;
}

.text-small {
  font-size: 24rpx;
}

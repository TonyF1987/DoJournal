/**
 * 深色模式共享样式（首页、积分页及子页面/弹窗）
 * 通过容器或弹窗根节点上的 .dark-mode 类生效
 */

.container.dark-mode,
.scroll-container.dark-mode {
  min-height: 100vh;
  background-color: #121212;
  color: #e8e8e8;
  box-sizing: border-box;
}

/* 演示/只读提示条 */
.dark-mode .demo-text {
  color: #f5f5f5 !important;
}

.dark-mode .demo-login-btn {
  background: rgba(255, 255, 255, 0.18) !important;
  color: #c8e6c9 !important;
  box-shadow: none;
  border: 1rpx solid rgba(129, 199, 132, 0.45);
}

.dark-mode .guide-btn {
  background: rgba(255, 255, 255, 0.18) !important;
  color: #c8e6c9 !important;
}

/* 弹窗与蒙层 */
.dark-mode.modal,
.dark-mode.checkin-modal,
.dark-mode.copy-calendar-full-modal,
.dark-mode.copy-modal-container {
  z-index: 999;
}

.dark-mode.copy-calendar-full-modal {
  background: rgba(0, 0, 0, 0.65) !important;
}

.dark-mode.copy-modal-container .modal-mask {
  background: rgba(0, 0, 0, 0.65) !important;
}

.dark-mode .modal-mask,
.dark-mode.checkin-modal .checkin-mask {
  background: rgba(0, 0, 0, 0.65) !important;
}

.dark-mode .modal-content,
.dark-mode .checkin-popup,
.dark-mode .copy-calendar-popup,
.dark-mode .copy-modal-content,
.dark-mode.copy-calendar-full-modal .copy-calendar-popup {
  background: #1e1e1e !important;
  color: #e8e8e8;
}

.dark-mode .modal-header,
.dark-mode .checkin-popup-header,
.dark-mode .copy-modal-header,
.dark-mode .copy-calendar-header {
  color: #ffffff !important;
  border-bottom-color: #333333 !important;
}

.dark-mode .modal-body,
.dark-mode .checkin-popup-body {
  background: #1e1e1e;
  color: #e8e8e8;
}

.dark-mode .modal-footer,
.dark-mode .checkin-popup-footer,
.dark-mode .copy-modal-footer {
  background: #1e1e1e !important;
  border-top-color: #333333 !important;
}

.dark-mode .close-btn,
.dark-mode .checkin-close,
.dark-mode .copy-modal-close,
.dark-mode .copy-calendar-close,
.dark-mode .copy-calendar-arrow {
  color: #b0b0b0 !important;
}

/* 表单 */
.dark-mode .form-label {
  color: #ffffff !important;
}

.dark-mode .form-input,
.dark-mode .form-textarea {
  background: #2c2c2c !important;
  color: #ffffff !important;
  border: 1rpx solid #404040;
}

.dark-mode .btn-cancel {
  background: #2c2c2c !important;
  color: #cccccc !important;
}

.dark-mode .checkin-btn-submit {
  background: #2a4a6a !important;
  color: #d4e6f6 !important;
  box-shadow: none !important;
}

.dark-mode .btn-danger {
  background: #4a3232 !important;
  color: #e8c4c4 !important;
  box-shadow: none !important;
}

/* 家庭 / 邀请 */
.dark-mode .family-info-card {
  background: linear-gradient(180deg, #1c2420 0%, #161b18 100%) !important;
}

.dark-mode .family-section .section-title {
  color: #ffffff !important;
}

.dark-mode .member-item {
  background: #2c2c2c !important;
}

.dark-mode .member-name {
  color: #ffffff !important;
}

.dark-mode .member-role {
  color: #999999 !important;
}

.dark-mode .family-empty-state .empty-text {
  color: #999999 !important;
}

.dark-mode .invite-code-card {
  background: #2c2c2c !important;
  border: 1rpx solid #404040;
}

.dark-mode .invite-code {
  color: #9eb0a0 !important;
}

.dark-mode .invite-tip,
.dark-mode .invite-tip text,
.dark-mode .join-tip,
.dark-mode .join-tip text {
  color: #999999 !important;
}

.dark-mode .invite-tip-small {
  color: #777777 !important;
}

/* 小朋友列表 */
.dark-mode .child-item {
  background: #2c2c2c !important;
  box-shadow: none;
}

.dark-mode .child-item.active {
  background: rgba(143, 168, 146, 0.15) !important;
  border: 2rpx solid rgba(143, 168, 146, 0.35) !important;
}

.dark-mode .child-name,
.dark-mode .child-card-name {
  color: #ffffff !important;
}

.dark-mode .child-school,
.dark-mode .child-card-school,
.dark-mode .child-meta,
.dark-mode .child-desc {
  color: #999999 !important;
}

.dark-mode .child-card-switch {
  color: #9eb0a0 !important;
}

.dark-mode .child-card {
  background: #2a2a2a !important;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.35);
}

.dark-mode .child-edit {
  background: #3a4a5a !important;
}

.dark-mode .child-delete {
  background: #4a2c2c !important;
}

.dark-mode .avatar-upload,
.dark-mode .gender-option,
.dark-mode .date-picker {
  background: #2c2c2c !important;
  color: #ffffff !important;
}

.dark-mode .gender-option.active {
  background: rgba(143, 168, 146, 0.15) !important;
  border-color: rgba(143, 168, 146, 0.35) !important;
}

.dark-mode .gender-option text {
  color: #ffffff !important;
}

/* 作业卡片与标签 */
.dark-mode .section-title,
.dark-mode .homework-title,
.dark-mode .subjects-header {
  color: #ffffff !important;
}

.dark-mode .subject-count {
  background: #333333 !important;
  color: #aaaaaa !important;
}

.dark-mode .points-tag {
  background: linear-gradient(135deg, #5d4e37, #8b6914) !important;
  color: #ffe082 !important;
}

.dark-mode .meta-tag {
  color: #9eb0a0 !important;

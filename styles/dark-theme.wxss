  color: #d4e6d6 !important;
  box-shadow: none !important;
}

.dark-mode .btn-secondary {
  color: #9eb0a0 !important;
  border-color: rgba(143, 168, 146, 0.35) !important;
}

.dark-mode .icon-option.selected,
.dark-mode .gender-option.active,
.dark-mode .child-item.active {
  background: rgba(143, 168, 146, 0.15) !important;
  border-color: rgba(143, 168, 146, 0.35) !important;
}

.dark-mode .btn-action.punishment {
  background: #4a3232 !important;
  color: #e8c4c4 !important;
}

.dark-mode .btn-action[disabled],
.dark-mode .btn-submit[disabled] {
  background: #2a2a2a !important;
  color: #666666 !important;
}

.dark-mode .stats-section {
  background: #1e1e1e !important;
}

.dark-mode .page-btn {
  background: #2a2a2a !important;
  color: #9eb0a0 !important;
  box-shadow: none !important;
}

.dark-mode .text-primary,
.dark-mode .action-btn,
.dark-mode .child-card-switch {
  color: #9eb0a0 !important;
}

.dark-mode .subject-item.active,
.dark-mode .tab-item.active .tab-text {
  color: #c5d8c7 !important;
}

.dark-mode .checkin-rating-item.active {
  background: rgba(143, 168, 146, 0.15) !important;
  border-color: rgba(143, 168, 146, 0.35) !important;
}

.dark-mode .calendar-day.selected,
.dark-mode .calendar-scroll-item.today,
.dark-mode .calendar-scroll-item.selected {
  background: rgba(143, 168, 146, 0.22) !important;
}

.dark-mode .calendar-day.today {
  background: rgba(143, 168, 146, 0.12) !important;
  border-color: rgba(143, 168, 146, 0.35) !important;
}

.dark-mode .calendar-day.today .day-text {
  color: #9eb0a0 !important;
}

.dark-mode .add-subject-btn {
  background: #354a38 !important;
  box-shadow: none !important;
}

/* 子页面：分享海报 */
.dark-mode .btn-save,
.dark-mode .btn-share {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.35);
}

/* ========== 添加作业 add ========== */
.dark-mode .subject-header {

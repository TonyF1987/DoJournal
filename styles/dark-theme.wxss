}

/* 复制弹窗 */
.dark-mode .copy-btn-cancel {
  background: #2c2c2c !important;
  color: #ffb74d !important;
  border-color: #ffb74d !important;
}

.dark-mode .copy-checkbox {
  background: #2c2c2c !important;
  border-color: #555555 !important;
}

.dark-mode .copy-date-text {
  color: #e0e0e0 !important;
}

.dark-mode .copy-date-disabled .copy-date-text {
  color: #666666 !important;
}

/* 打卡页 */
.dark-mode .card {
  background: #1e1e1e !important;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.35);
}

.dark-mode .rating-result {
  background: linear-gradient(135deg, #3e3a20, #2e2a18) !important;
}

.dark-mode .result-text {
  color: #cccccc !important;
}

.dark-mode .result-points {

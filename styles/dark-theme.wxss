}

.dark-mode .btn-action,
.dark-mode .add-btn,
.dark-mode .add-btn-text,
.dark-mode .correct-btn,
.dark-mode .checkin-btn-quick,
.dark-mode .btn-primary,
.dark-mode .btn-confirm,
.dark-mode .btn-confirm:not(.btn-danger),
.dark-mode .btn-add-subject,
.dark-mode .btn-primary {

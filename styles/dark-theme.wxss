}

.dark-mode .rating-item.active.excellent {
  background: rgba(143, 168, 146, 0.15) !important;
  border-color: rgba(143, 168, 146, 0.35) !important;
}

.dark-mode .rating-item.active.good {
  background: rgba(33, 150, 243, 0.22) !important;
  border-color: #64b5f6 !important;
}

.dark-mode .rating-item.active.pass {
  background: rgba(255, 152, 0, 0.22) !important;
  border-color: #ffb74d !important;
}

.dark-mode .rating-label {
  color: #cccccc !important;
}

/* ========== 深色模式柔和绿色（降低与黑色背景反差） ========== */

.dark-mode .header-gradient,
.dark-mode .top-header {
  background: linear-gradient(180deg, #1c2420 0%, #161b18 50%, #121212 100%) !important;
}

.dark-mode .user-card {
  background: #242424 !important;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: none !important;
}

.dark-mode .stats-row {
  background: rgba(143, 168, 146, 0.08) !important;
  border: 1rpx solid rgba(143, 168, 146, 0.1);
}

.dark-mode .tab-bar {
  background: #1a1a1a !important;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25) !important;
}

.dark-mode .tab-item.active {
  background: rgba(143, 168, 146, 0.16) !important;
  color: #c5d8c7 !important;
  box-shadow: none !important;
  border: 1rpx solid rgba(143, 168, 146, 0.22);
}

.dark-mode .content-area {
  background: transparent !important;
}

.dark-mode .item-emoji {
  background: #252f27 !important;
}

.dark-mode .item-points,
.dark-mode .grid-points,
.dark-mode .list-item-points,
.dark-mode .record-points.reward,
.dark-mode .grid-points:not(.negative),

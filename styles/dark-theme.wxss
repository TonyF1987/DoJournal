  color: #c5d8c7 !important;
  border-color: rgba(143, 168, 146, 0.35) !important;
}

.dark-mode .btn-submit,
.dark-mode .btn-add-new {
  background: #354a38 !important;
  color: #d4e6d6 !important;
  box-shadow: none !important;
}

.dark-mode .btn-add-new {
